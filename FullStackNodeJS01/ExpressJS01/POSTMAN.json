  "item": [
    {
      "name": "1. Đăng ký (Register)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Hải Dương\",\n    \"email\": \"haiduong@gmail.com\",\n    \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": ["{{baseUrl}}"],
          "path": ["register"]
        }
      },
      "response": []
    },
    {
      "name": "2. Đăng nhập (Login)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData && jsonData.access_token) {",
              "    pm.collectionVariables.set(\"token\", jsonData.access_token);",
              "    console.log(\"Token đã được lưu tự động!\");",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"haiduong@gmail.com\",\n    \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      },
      "response": []
    },
    {
      "name": "3. Lấy ds User (Get User)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user",
          "host": ["{{baseUrl}}"],
          "path": ["user"]
        }
      },
      "response": []
    },
    {
      "name": "4. Lấy Account (Delay 3s)",
